generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  username             String?             @unique
  email                String?             @unique
  emailVerified        Boolean             @default(false)
  emailDisabled        Boolean             @default(false)
  twoFactorPending     Boolean             @default(false)
  passwordHash         String?
  name                 String?
  role                 Role                @default(RESELLER)
  avatarUrl            String?
  walletBalance        Float               @default(0)
  currencyPreference   String              @default("INR")
  isBanned             Boolean             @default(false)
  resellerExpiresAt    DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  resellerSuspicious   Boolean             @default(false)
  membershipExpiresAt  DateTime?
  membershipMonths     Int?
  adminNote            String?
  currentSessionDevice String?
  currentSessionIp     String?
  currentSessionToken  String?
  isFrozen             Boolean             @default(false)
  lastSeenAt           DateTime?
  isReseller           Boolean             @default(false)
  otpCodes             OtpCode[]
  resellerSession      ResellerSession?
  accountsPurchased    AccountListing[]    @relation("SoldToUser")
  loginHistory         LoginHistory[]
  orders               Order[]
  supportTickets       SupportTicket[]
  transactions         WalletTransaction[]
}

model ResellerSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique @default(cuid())
  ip        String?
  userAgent String?
  lastSeen  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  type      String   // EMAIL_VERIFY | LOGIN_2FA | PASSWORD_RESET
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  sessionId String
  ip        String
  userAgent String
  updatedAt DateTime @updatedAt
}

model SuspiciousActivity {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model AdminAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("ADMIN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model SmilecoinConfig {
  id               String   @id @default(cuid())
  smilecoinsAmount Float
  inrPaid          Float
  markupPercent    Float    @default(1.1)
  updatedAt        DateTime @updatedAt
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ip        String
  userAgent String
  country   String?
  city      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model InviteLink {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())
  createdBy       String
  usedBy          String?
  usedAt          DateTime?
  expiresAt       DateTime
  isUsed          Boolean   @default(false)
  membershipMonths Int      @default(1)
  requireEmail    Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model MembershipPayment {
  id        String   @id @default(cuid())
  userId    String
  months    Int
  amountInr Float
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Game {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?
  coverImage        String?
  isActive          Boolean          @default(true)
  supplierName      String?
  supplierBaseUrl   String?
  supplierConfig    Json?            @default("{}")
  inputFields       Json?            @default("[]")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  accounts          AccountListing[]
  applicableCoupons Coupon[]
  packages          DiamondPackage[]
  orders            Order[]
}

model Order {
  id               String          @id @default(cuid())
  userId           String
  gameId           String
  type             OrderType
  productId        String
  quantity         Int             @default(1)
  unitPrice        Float
  totalPrice       Float
  discountApplied  Float           @default(0)
  cashbackCredited Float           @default(0)
  paymentMethod    String
  paymentStatus    String
  orderStatus      String
  playerInputs     Json?           @default("{}")
  mlbbUsername     String?
  couponCode       String?
  supplierOrderId  String?
  notes            String?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  game             Game            @relation(fields: [gameId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  supportTickets   SupportTicket[]
}

model WalletTransaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Float
  currency    String          @default("INR")
  method      String
  referenceId String?
  status      String
  description String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])
}

model DiamondPackage {
  id                String   @id @default(cuid())
  gameId            String
  diamondAmount     Int
  basePriceInr      Float
  displayPrice      Float?
  section           String   @default("standard")
  isVisible         Boolean  @default(true)
  bonusDiamonds     Int      @default(0)
  bonusLabel        String?
  supplierProductId String
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  game              Game     @relation(fields: [gameId], references: [id])
}

model AccountListing {
  id                 String   @id @default(cuid())
  gameId             String
  rank               String
  server             String
  heroCount          Int
  skinCount          Int
  priceInr           Float
  screenshots        Json?    @default("[]")
  credentialEmail    String
  credentialPassword String
  isSold             Boolean  @default(false)
  soldToUserId       String?
  createdAt          DateTime @default(now())
  game               Game     @relation(fields: [gameId], references: [id])
  soldToUser         User?    @relation("SoldToUser", fields: [soldToUserId], references: [id])
}

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  discountPercent  Float
  maxUses          Int
  usedCount        Int       @default(0)
  minOrderValue    Float     @default(0)
  expiryDate       DateTime?
  applicableGameId String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  applicableGame   Game?     @relation(fields: [applicableGameId], references: [id])
}

model Banner {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  ctaText       String?
  ctaLink       String?
  imageUrl      String?
  gradientStart String   @default("#ffd700")
  gradientEnd   String   @default("#f59e0b")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  contentConfig Json?    @default("[]")
  imageConfig   Json?    @default("{\"x\": 0, \"y\": 0, \"scale\": 1}")
  createdAt     DateTime @default(now())
}

model PricingConfig {
  id                    String   @id @default(cuid())
  userMarkupPercent     Float    @default(3.5)
  resellerMarkupPercent Float    @default(1.5)
  refreshIntervalHours  Float    @default(2.0)
  inviteLinkExpiryHours Float    @default(2.0)
  landingPageDiscountPercent Float @default(0)
  updatedAt             DateTime @updatedAt
}

model SupportTicket {
  id         String    @id @default(cuid())
  userId     String
  orderId    String?
  subject    String
  status     String
  messages   Json?     @default("[]")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  order      Order?    @relation(fields: [orderId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

enum Role {
  RESELLER
  ADMIN
  SUPER_ADMIN
}

enum OrderType {
  TOPUP
  ACCOUNT
}

enum TransactionType {
  CREDIT
  DEBIT
}
